{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Beatport DJ Suite (Electron)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "desktop:dev"],
      "port": 9222
    },
    {
      "name": "Beatport Scanner (CLI)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "beatport:scan"],
      "port": null
    },
    {
      "name": "Diagnose / Check",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "check"],
      "port": null
    },
    {
      "name": "Smoke-Test Beatport",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "smoke:beatport"],
      "port": null
    }
  ]
}
