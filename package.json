{
  "name": "beatport-dj-suite",
  "version": "4.2.10",
  "private": true,
  "type": "module",
  "author": "Robert H.",
  "description": "Beatport DJ Suite — Scanner, Analyse, Playlist-Management & Automation (macOS)",
  "main": "electron-app/main.mjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "desktop:dev": "electron .",
    "browser-devtools:app": "electron plugins/browser-devtools-automation/app/main.mjs",
    "desktop:dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip",
    "desktop:dir:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir",
    "test": "node --test $(find tests packages/*/tests -name '*.test.mjs' 2>/dev/null)",
    "test:packages": "node --test $(find packages/*/tests -name '*.test.mjs' 2>/dev/null)",
    "test:coverage": "node --test --experimental-test-coverage $(find tests packages/*/tests -name '*.test.mjs' 2>/dev/null)",
    "test:unit": "node --test tests/beatport-scanner.test.mjs tests/unified-integrations.test.mjs tests/export-formats.test.mjs tests/api-clients.test.mjs",
    "test:integration": "node --test tests/cdp-scanner-integration.test.mjs tests/ipc-channel-consistency.test.mjs tests/session-manager.test.mjs",
    "test:smoke": "node --test tests/app-bundle-smoke.test.mjs",
    "check": "node scripts/check-scanner.mjs",
    "smoke:beatport": "node scripts/smoke-beatport.mjs",
    "beatport:scan": "node tools/bpx.mjs scan",
    "beatport:delete": "node tools/bpx.mjs delete",
    "release": "commit-and-tag-version && git push --follow-tags origin v4",
    "release:patch": "commit-and-tag-version --release-as patch && git push --follow-tags origin v4",
    "release:minor": "commit-and-tag-version --release-as minor && git push --follow-tags origin v4",
    "release:major": "commit-and-tag-version --release-as major && git push --follow-tags origin v4"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.7.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "build": {
    "appId": "com.roberth.beatport.djsuite",
    "productName": "Beatport DJ Suite",
    "asarUnpack": [
      "electron-app/integrations/python/**/*.py"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-app/**/*",
      "package.json"
    ],
    "icon": "assets/icon.icns",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
