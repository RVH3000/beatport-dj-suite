{
  "name": "@bpdjs/engine-db-core",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Engine-DJ Core Library: read-only DB-Layer, History, Rating, Streaming-URI, Exporter (Rekordbox, CSV, Engine-USB), Lexicon-Client, Playlist-Splitter. Plain-Copy aus engine-dj-manager (MIT-License, siehe LICENSE.engine-dj-manager).",
  "source": "engine-dj-manager@master b0aea62 / 839aac0 — Stand 2026-05-13",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./engine-db": {
      "types": "./dist/engine-db.d.ts",
      "import": "./dist/engine-db.js"
    },
    "./engine-history-db": {
      "types": "./dist/engine-history-db.d.ts",
      "import": "./dist/engine-history-db.js"
    },
    "./db-scanner": {
      "types": "./dist/db-scanner.d.ts",
      "import": "./dist/db-scanner.js"
    },
    "./db-compare": {
      "types": "./dist/db-compare.d.ts",
      "import": "./dist/db-compare.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./export-engine-usb": {
      "types": "./dist/export-engine-usb.d.ts",
      "import": "./dist/export-engine-usb.js"
    },
    "./auto-history-playlist": {
      "types": "./dist/auto-history-playlist.d.ts",
      "import": "./dist/auto-history-playlist.js"
    },
    "./engine-schema": {
      "types": "./dist/engine-schema.d.ts",
      "import": "./dist/engine-schema.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE.engine-dj-manager"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "node --test tests/*.test.mjs 2>/dev/null || echo 'no tests yet'"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.7.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
